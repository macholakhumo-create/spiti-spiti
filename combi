<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
  <meta name="mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <title>Spiti-Spiti Combi</title>
  <script src="https://cdn.socket.io/4.7.5/socket.io.min.js"></script>
  <style>
    * { margin:0; padding:0; box-sizing:border-box; }
    body { font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif; background:#F5F0EA; color:#1C1917; min-height:100vh; }
    nav { background:#fff; border-bottom:1px solid #E5DDD0; padding:14px 20px; display:flex; align-items:center; justify-content:space-between; position:sticky; top:0; z-index:100; }
    .brand { font-size:1rem; font-weight:700; letter-spacing:-0.03em; display:flex; align-items:center; gap:6px; }
    .brand span { color:#F97316; }
    .nav-right { display:flex; align-items:center; gap:10px; }
    .conn-dot { width:14px; height:14px; display:flex; align-items:center; justify-content:center; }
    .conn-dot svg { fill:#D4CCBF; transition:all 0.3s; }
    .conn-dot.live svg { fill:#22c55e; filter:drop-shadow(0 0 4px #22c55e88); }
    .logout-btn { background:none; border:1px solid #E5DDD0; color:#78716C; font-family:inherit; font-size:0.7rem; padding:5px 10px; border-radius:8px; cursor:pointer; }
    .logout-btn:hover { border-color:#ef4444; color:#ef4444; }
    .container { max-width:480px; margin:0 auto; padding:16px 16px 100px; }
    .greeting { font-size:1.3rem; font-weight:700; letter-spacing:-0.03em; margin-bottom:2px; }
    .greeting-sub { font-size:0.8rem; color:#78716C; margin-bottom:20px; }
    .card { background:#fff; border:1px solid #E5DDD0; border-radius:16px; padding:18px; margin-bottom:14px; }
    .card-label { font-size:0.62rem; font-weight:700; letter-spacing:0.12em; text-transform:uppercase; color:#F97316; margin-bottom:14px; display:flex; align-items:center; gap:5px; }
    .card-label svg { width:12px; height:12px; stroke:#F97316; fill:none; stroke-width:2.5; }

    /* STATUS TOGGLE */
    .status-row { display:flex; align-items:center; justify-content:space-between; margin-bottom:16px; }
    .status-info .status-main { font-size:0.9rem; font-weight:700; color:#1C1917; }
    .status-info .status-sub { font-size:0.7rem; color:#78716C; margin-top:2px; }
    .sw { width:52px; height:28px; background:#E5DDD0; border-radius:28px; padding:3px; cursor:pointer; transition:background 0.3s; }
    .sw.on { background:#F97316; }
    .sw-knob { width:22px; height:22px; background:#fff; border-radius:50%; box-shadow:0 1px 4px rgba(0,0,0,0.15); transform:translateX(0); transition:transform 0.3s cubic-bezier(0.4,0,0.2,1); }
    .sw.on .sw-knob { transform:translateX(24px); }

    /* ROUTE SELECT */
    .field { margin-bottom:12px; }
    .field label { display:block; font-size:0.7rem; color:#78716C; margin-bottom:4px; font-weight:500; }
    .field select { width:100%; background:#F5F0EA; border:1px solid #E5DDD0; border-radius:10px; padding:11px 13px; color:#1C1917; font-family:inherit; font-size:0.85rem; outline:none; }
    .field select:focus { border-color:#F97316; }

    /* CAPACITY BUTTONS */
    .cap-row { display:grid; grid-template-columns:1fr 1fr 1fr; gap:8px; margin-bottom:14px; }
    .cap-btn { padding:10px; border-radius:10px; font-family:inherit; font-size:0.78rem; font-weight:700; cursor:pointer; border:2px solid #E5DDD0; background:#F5F0EA; color:#78716C; transition:all 0.2s; text-align:center; }
    .cap-btn.active-available { border-color:#22c55e; background:#dcfce7; color:#16a34a; }
    .cap-btn.active-one { border-color:#f59e0b; background:#FFF7ED; color:#d97706; }
    .cap-btn.active-full { border-color:#ef4444; background:#fee2e2; color:#dc2626; }
    .cap-btn:hover { opacity:0.85; }

    /* FARE INFO */
    .fare-info { background:#FFF7ED; border:1px solid #FED7AA; border-radius:10px; padding:12px 14px; display:flex; align-items:center; justify-content:space-between; margin-bottom:14px; }
    .fare-info-label { font-size:0.68rem; color:#78716C; }
    .fare-info-val { font-size:1.1rem; font-weight:700; color:#F97316; }
    .fare-info-note { font-size:0.6rem; color:#A8A29E; margin-top:2px; }

    /* LIVE MAP */
    .map-wrap { border-radius:12px; overflow:hidden; height:220px; position:relative; background:#EDE8E0; margin-bottom:14px; }
    #combi-gmap { width:100%; height:100%; }
    .map-badge { position:absolute; top:8px; left:8px; background:rgba(255,255,255,0.95); border:1px solid #E5DDD0; border-radius:8px; padding:5px 10px; font-size:0.68rem; font-weight:600; display:flex; align-items:center; gap:6px; pointer-events:none; }
    .live-dot { width:6px; height:6px; border-radius:50%; background:#D4CCBF; }
    .live-dot.on { background:#22c55e; animation:blink 1.5s infinite; }
    @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.3} }

    /* PASSENGER PINGS */
    .pings-section { margin-bottom:14px; }
    .pings-head { font-size:0.62rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:#F97316; margin-bottom:8px; display:flex; align-items:center; justify-content:space-between; }
    .pings-head span { font-weight:400; color:#A8A29E; letter-spacing:0; text-transform:none; }
    .ping-item { background:#F5F0EA; border-radius:10px; padding:10px 12px; margin-bottom:6px; display:flex; align-items:center; justify-content:space-between; animation:slideIn 0.2s ease; }
    @keyframes slideIn { from{opacity:0;transform:translateY(-4px)} to{opacity:1;transform:translateY(0)} }
    .ping-loc { font-size:0.8rem; font-weight:500; color:#1C1917; }
    .ping-meta { font-size:0.65rem; color:#78716C; margin-top:2px; }
    .ping-dist { font-size:0.72rem; color:#F97316; font-weight:600; }
    .empty { text-align:center; color:#A8A29E; font-size:0.78rem; padding:16px; }

    /* STATS */
    .stats-row { display:grid; grid-template-columns:1fr 1fr 1fr; gap:10px; margin-bottom:14px; }
    .stat { background:#F5F0EA; border-radius:10px; padding:12px; text-align:center; }
    .stat-num { font-size:1.4rem; font-weight:700; color:#F97316; }
    .stat-lbl { font-size:0.6rem; color:#A8A29E; margin-top:2px; }

    .btn { width:100%; padding:12px; border:none; border-radius:10px; font-family:inherit; font-size:0.85rem; font-weight:600; cursor:pointer; transition:all 0.2s; display:flex; align-items:center; justify-content:center; gap:6px; margin-bottom:8px; }
    .btn svg { width:15px; height:15px; stroke:currentColor; fill:none; stroke-width:2.5; stroke-linecap:round; }
    .btn-primary { background:#F97316; color:#fff; }
    .btn-ghost { background:#EDE8E0; color:#78716C; border:1px solid #E5DDD0; }
    .btn:hover { opacity:0.88; }
    .btn:last-child { margin-bottom:0; }

    .toast { position:fixed; bottom:20px; left:50%; transform:translateX(-50%); background:#1C1917; color:#fff; padding:11px 22px; border-radius:10px; font-size:0.8rem; font-weight:600; opacity:0; transition:opacity 0.3s; pointer-events:none; z-index:1200; max-width:88vw; text-align:center; }
    .toast.show { opacity:1; }
    .toast.warn { background:#F97316; }
    .toast.error { background:#ef4444; }
  </style>
</head>
<body>

<nav>
  <div class="brand">
    <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
      <rect x="1" y="7" width="16" height="7" rx="2" fill="#F97316"/>
      <path d="M3 7V5C3 3.3 4.3 2 6 2H12C13.7 2 15 3.3 15 5V7" stroke="#F97316" stroke-width="1.5" fill="none"/>
      <circle cx="5" cy="14" r="2" fill="#1C1917"/><circle cx="13" cy="14" r="2" fill="#1C1917"/>
      <circle cx="5" cy="14" r="1" fill="#F5F0EA"/><circle cx="13" cy="14" r="1" fill="#F5F0EA"/>
    </svg>
    Spiti-Spiti<span>.</span>
  </div>
  <div class="nav-right">
    <div class="conn-dot" id="dot"><svg width="8" height="8" viewBox="0 0 8 8"><circle cx="4" cy="4" r="4"/></svg></div>
    <button class="logout-btn" onclick="logout()">Logout</button>
  </div>
</nav>

<div class="container">
  <div class="greeting" id="greeting">Combi Dashboard</div>
  <div class="greeting-sub">Manage your route and passengers</div>

  <!-- ON DUTY CARD -->
  <div class="card">
    <div class="card-label">
      <svg viewBox="0 0 24 24"><rect x="1" y="3" width="15" height="13" rx="2"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
      Combi Status
    </div>

    <div class="status-row">
      <div class="status-info">
        <div class="status-main" id="duty-label">Go Online</div>
        <div class="status-sub" id="duty-sub">Start sharing your location</div>
      </div>
      <div class="sw" id="duty-sw" onclick="toggleDuty()"><div class="sw-knob"></div></div>
    </div>

    <!-- ROUTE -->
    <div class="field">
      <label>Select Your Route</label>
      <select id="route-select" onchange="onRouteChange()">
        <option value="">-- Choose a route --</option>
        <option value="Station → Game City">Station → Game City</option>
        <option value="Station → Broadhurst">Station → Broadhurst</option>
        <option value="Station → Tlokweng">Station → Tlokweng</option>
        <option value="Station → Mogoditshane">Station → Mogoditshane</option>
        <option value="Station → Mogoditshane Block 6">Station → Mogoditshane Block 6</option>
        <option value="Station → Gabane">Station → Gabane</option>
        <option value="Station → Mmopane">Station → Mmopane</option>
        <option value="Station → Old Naledi">Station → Old Naledi</option>
        <option value="Station → Bontleng">Station → Bontleng</option>
        <option value="Station → Extension 14">Station → Extension 14</option>
        <option value="Station → Riverwalk">Station → Riverwalk</option>
        <option value="Game City → Mogoditshane">Game City → Mogoditshane</option>
        <option value="Riverwalk → Tlokweng">Riverwalk → Tlokweng</option>
        <option value="Main Mall → Airport">Main Mall → Airport</option>
      </select>
    </div>

    <!-- FARE INFO -->
    <div class="fare-info">
      <div>
        <div class="fare-info-label">Standard Combi Fare</div>
        <div class="fare-info-note">Set by Dept. of Transport</div>
      </div>
      <div style="text-align:right">
        <div class="fare-info-val">P3.50</div>
        <div class="fare-info-note">per passenger</div>
      </div>
    </div>

    <!-- CAPACITY -->
    <div class="field"><label>Capacity Status</label></div>
    <div class="cap-row">
      <div class="cap-btn" id="cap-available" onclick="setCapacity('available')">✅ Available</div>
      <div class="cap-btn" id="cap-one" onclick="setCapacity('one_space')">⚠️ One Space</div>
      <div class="cap-btn" id="cap-full" onclick="setCapacity('full')">🔴 Full</div>
    </div>

    <button class="btn btn-primary" id="start-btn" onclick="startTrip()" style="display:none">
      <svg viewBox="0 0 24 24"><polygon points="5 3 19 12 5 21 5 3"/></svg>
      Start Broadcasting
    </button>
    <button class="btn btn-ghost" id="stop-btn" onclick="stopTrip()" style="display:none">
      <svg viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/></svg>
      End Trip
    </button>
  </div>

  <!-- STATS -->
  <div class="stats-row">
    <div class="stat"><div class="stat-num" id="stat-pings">0</div><div class="stat-lbl">Waiting</div></div>
    <div class="stat"><div class="stat-num" id="stat-trips">0</div><div class="stat-lbl">Trips Today</div></div>
    <div class="stat"><div class="stat-num" id="stat-km">0</div><div class="stat-lbl">km Driven</div></div>
  </div>

  <!-- LIVE MAP -->
  <div class="map-wrap">
    <div id="combi-gmap"></div>
    <div class="map-badge">
      <div class="live-dot" id="live-dot"></div>
      <span id="map-txt">Location off</span>
    </div>
  </div>

  <!-- PASSENGER PINGS -->
  <div class="card">
    <div class="card-label">
      <svg viewBox="0 0 24 24"><circle cx="12" cy="10" r="3"/><path d="M12 21C12 21 5 14 5 10a7 7 0 0 1 14 0c0 4-7 11-7 11z"/></svg>
      Passengers Waiting Ahead
    </div>
    <div id="pings-list"><div class="empty">No passengers waiting on this route yet</div></div>
  </div>
</div>

<div class="toast" id="toast"></div>

<script>
  const BASE = "https://spiti-spiti-production.up.railway.app";
  const driverData = JSON.parse(localStorage.getItem("spiti_driver") || "null");
  if (!driverData) { window.location.replace("login.html"); throw new Error("Not authenticated"); }
  const DRIVER_ID = driverData.id;
  const DRIVER_NAME = driverData.name;

  document.getElementById("greeting").textContent = `Hey ${DRIVER_NAME.split(" ")[0]}`;

  function logout() { localStorage.removeItem("spiti_driver"); window.location.replace("login.html"); }

  let gmap = null, selfMarker = null, locInterval = null;
  let isOnDuty = false, currentRoute = "", currentCapacity = "available";
  let tripActive = false, tripsToday = 0, kmDriven = 0;
  let currentLat = null, currentLng = null;
  let passengerMarkers = {};

  const GMAPS_KEY = "AIzaSyC0tqvQPPWHh3gL1ExnRo-Lzh0QNGVcYHk";

  // ── GOOGLE MAPS ──────────────────────────────────────────
  function initCombiMap() {
    gmap = new google.maps.Map(document.getElementById("combi-gmap"), {
      center: { lat: -24.6541, lng: 25.9087 },
      zoom: 13,
      disableDefaultUI: true,
      zoomControl: true,
      styles: [
        { featureType: "poi", stylers: [{ visibility: "off" }] },
        { elementType: "geometry", stylers: [{ color: "#f5f0ea" }] },
        { featureType: "road", elementType: "geometry", stylers: [{ color: "#ffffff" }] },
        { featureType: "road.arterial", elementType: "geometry", stylers: [{ color: "#E5DDD0" }] },
        { featureType: "water", elementType: "geometry", stylers: [{ color: "#c9e4f0" }] }
      ]
    });
  }

  window.addEventListener("load", () => {
    const s = document.createElement("script");
    s.src = `https://maps.googleapis.com/maps/api/js?key=${GMAPS_KEY}&callback=initCombiMap`;
    s.async = true; s.defer = true;
    document.head.appendChild(s);
  });

  // ── SOCKET ────────────────────────────────────────────────
  const socket = io(BASE, { transports: ["websocket", "polling"] });
  socket.on("connect", () => {
    document.getElementById("dot").classList.add("live");
    socket.emit("join-role", { role: "drivers", userId: DRIVER_ID });
  });
  socket.on("disconnect", () => document.getElementById("dot").classList.remove("live"));

  // Listen for passengers pinging on our route
  socket.on("passenger-waiting", (data) => {
    if (data.route !== currentRoute) return;
    addPassengerPing(data);
    showToast(`Passenger waiting ahead on ${data.route}`, "warn");
  });
  socket.on("passenger-boarding", (data) => {
    removePing(data.passengerId);
  });

  // ── DUTY TOGGLE ───────────────────────────────────────────
  function toggleDuty() {
    isOnDuty = !isOnDuty;
    const sw = document.getElementById("duty-sw");
    sw.classList.toggle("on", isOnDuty);
    document.getElementById("duty-label").textContent = isOnDuty ? "Online" : "Go Online";
    document.getElementById("duty-sub").textContent = isOnDuty ? "You are broadcasting" : "Start sharing your location";
    if (isOnDuty) {
      startLocation();
      document.getElementById("start-btn").style.display = "flex";
    } else {
      stopTrip();
      stopLocation();
      document.getElementById("start-btn").style.display = "none";
      document.getElementById("stop-btn").style.display = "none";
    }
  }

  function onRouteChange() {
    currentRoute = document.getElementById("route-select").value;
  }

  function setCapacity(cap) {
    currentCapacity = cap;
    document.getElementById("cap-available").className = "cap-btn" + (cap === "available" ? " active-available" : "");
    document.getElementById("cap-one").className = "cap-btn" + (cap === "one_space" ? " active-one" : "");
    document.getElementById("cap-full").className = "cap-btn" + (cap === "full" ? " active-full" : "");
    // Broadcast capacity change if trip is active
    if (tripActive && currentLat) broadcastLocation();
  }

  // ── TRIP CONTROL ──────────────────────────────────────────
  function startTrip() {
    if (!currentRoute) { showToast("Please select a route first", "warn"); return; }
    tripActive = true;
    tripsToday++;
    document.getElementById("stat-trips").textContent = tripsToday;
    document.getElementById("start-btn").style.display = "none";
    document.getElementById("stop-btn").style.display = "flex";
    showToast(`Broadcasting on ${currentRoute}`);
  }

  function stopTrip() {
    tripActive = false;
    document.getElementById("stop-btn").style.display = "none";
    if (isOnDuty) document.getElementById("start-btn").style.display = "flex";
    // Tell server trip ended
    socket.emit("combi-offline", { driverId: DRIVER_ID });
    showToast("Trip ended");
  }

  // ── LOCATION ──────────────────────────────────────────────
  function startLocation() {
    if (!navigator.geolocation) return showToast("Location not supported", "error");
    document.getElementById("live-dot").classList.add("on");
    sendLocation();
    locInterval = setInterval(sendLocation, 4000);
  }

  function stopLocation() {
    clearInterval(locInterval); locInterval = null;
    document.getElementById("live-dot").classList.remove("on");
    document.getElementById("map-txt").textContent = "Location off";
  }

  function sendLocation() {
    navigator.geolocation.getCurrentPosition(pos => {
      const { latitude: lat, longitude: lng } = pos.coords;
      currentLat = lat; currentLng = lng;
      document.getElementById("map-txt").textContent = `${lat.toFixed(4)}, ${lng.toFixed(4)}`;
      updateSelfOnMap(lat, lng);
      if (tripActive) broadcastLocation();
    }, err => {
      showToast("Location error — check permissions", "error");
      stopLocation();
    }, { enableHighAccuracy: true, timeout: 10000, maximumAge: 3000 });
  }

  function broadcastLocation() {
    socket.emit("combi-location", {
      driverId: DRIVER_ID,
      driverName: DRIVER_NAME,
      route: currentRoute,
      capacity: currentCapacity,
      lat: currentLat,
      lng: currentLng
    });
    // Also persist to server
    fetch(`${BASE}/drivers/${DRIVER_ID}/location`, {
      method: "PATCH", headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ lat: currentLat, lng: currentLng })
    }).catch(() => {});
  }

  function updateSelfOnMap(lat, lng) {
    if (!gmap) return;
    const pos = { lat, lng };
    if (!selfMarker) {
      selfMarker = new google.maps.Marker({
        position: pos, map: gmap, title: "You",
        icon: {
          url: "data:image/svg+xml;charset=UTF-8," + encodeURIComponent(`
            <svg xmlns="http://www.w3.org/2000/svg" width="44" height="44" viewBox="0 0 44 44">
              <circle cx="22" cy="22" r="20" fill="#F97316" stroke="#fff" stroke-width="3"/>
              <text x="22" y="28" text-anchor="middle" font-size="20" fill="white">🚌</text>
            </svg>`),
          scaledSize: new google.maps.Size(44, 44),
          anchor: new google.maps.Point(22, 22)
        }, zIndex: 10
      });
    } else {
      selfMarker.setPosition(pos);
    }
    gmap.setCenter(pos);
  }

  // ── PASSENGER PINGS ───────────────────────────────────────
  function addPassengerPing(data) {
    const list = document.getElementById("pings-list");
    const empty = list.querySelector(".empty");
    if (empty) empty.remove();

    // Map marker
    if (gmap && data.lat && data.lng) {
      if (passengerMarkers[data.passengerId]) passengerMarkers[data.passengerId].setMap(null);
      passengerMarkers[data.passengerId] = new google.maps.Marker({
        position: { lat: data.lat, lng: data.lng }, map: gmap, title: "Waiting passenger",
        icon: {
          url: "data:image/svg+xml;charset=UTF-8," + encodeURIComponent(`
            <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 36 36">
              <circle cx="18" cy="18" r="16" fill="#1C1917" stroke="#fff" stroke-width="2.5"/>
              <text x="18" y="23" text-anchor="middle" font-size="16" fill="white">🧍</text>
            </svg>`),
          scaledSize: new google.maps.Size(36, 36),
          anchor: new google.maps.Point(18, 18)
        }, zIndex: 20
      });
    }

    // Distance
    let dist = "—";
    if (currentLat && data.lat) {
      const R = 6371, dLat = (data.lat - currentLat) * Math.PI / 180, dLng = (data.lng - currentLng) * Math.PI / 180;
      const a = Math.sin(dLat/2)**2 + Math.cos(currentLat*Math.PI/180)*Math.cos(data.lat*Math.PI/180)*Math.sin(dLng/2)**2;
      dist = (R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a))).toFixed(1) + " km";
    }

    const el = document.createElement("div");
    el.className = "ping-item";
    el.id = `ping-${data.passengerId}`;
    el.innerHTML = `
      <div>
        <div class="ping-loc">📍 ${data.location || "Nearby"}</div>
        <div class="ping-meta">${data.route}</div>
      </div>
      <div class="ping-dist">${dist} away</div>`;
    list.prepend(el);
    document.getElementById("stat-pings").textContent = list.querySelectorAll(".ping-item").length;
  }

  function removePing(passengerId) {
    const el = document.getElementById(`ping-${passengerId}`);
    if (el) el.remove();
    if (passengerMarkers[passengerId]) { passengerMarkers[passengerId].setMap(null); delete passengerMarkers[passengerId]; }
    const list = document.getElementById("pings-list");
    if (!list.querySelectorAll(".ping-item").length) list.innerHTML = '<div class="empty">No passengers waiting on this route yet</div>';
    document.getElementById("stat-pings").textContent = list.querySelectorAll(".ping-item").length;
  }

  function showToast(msg, type = "") {
    const t = document.getElementById("toast");
    t.textContent = msg;
    t.className = "toast show" + (type ? " " + type : "");
    setTimeout(() => t.className = "toast", 3500);
  }
</script>
</body>
</html>
